local function optimizeCharacter(char)
    if not char or char == LP.Character then return end
    if processedObjects[char] then return end
    processedObjects[char] = true
    
    task.defer(function()
        task.wait(0.2)
        if not isEnabled or not char:IsDescendantOf(workspace) then 
            processedObjects[char] = nil
            return 
        end
        local descendants = char:GetDescendants()
        for i = 1, #descendants do
            local v = descendants[i]
            if v:IsA("Accessory") or v:IsA("Shirt") or v:IsA("Pants") or v:IsA("ShirtGraphic") or v:IsA("FaceControls") then
                if not original[v] then original[v] = {Parent = v.Parent} end
                v.Parent = nil
            elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") or v:IsA("Highlight") or v:IsA("Sparkles") or v:IsA("Fire") or v:IsA("Smoke") then
                if not original[v] then original[v] = {Enabled = v.Enabled} end
                v.Enabled = false
            elseif v:IsA("Decal") or v:IsA("Texture") then
                if not original[v] then original[v] = {Texture = v.Texture, Trans = v.Transparency} end
                v.Texture = ""
                v.Transparency = 1
            elseif v:IsA("BasePart") or v:IsA("MeshPart") then
                if not original[v] then original[v] = {Mat = v.Material, Shadow = v.CastShadow, Ref = v.Reflectance} end
                v.Material = Enum.Material.SmoothPlastic
                v.CastShadow = false
                v.Reflectance = 0
                if v:IsA("MeshPart") then
                    if not original[v].MeshId then original[v].MeshId = v.MeshId end
                    if not original[v].TextureId then original[v].TextureId = v.TextureId end
                    v.TextureId = ""
                end
            elseif v:IsA("SpecialMesh") then
                if not original[v] then original[v] = {TextureId = v.TextureId, MeshType = v.MeshType, MeshId = v.MeshId} end
                v.TextureId = ""
                v.MeshId = ""
                v.MeshType = Enum.MeshType.Box
            end
        end
    end)
end

local function optimize(v)
    if not v or processedObjects[v] then return end
    processedObjects[v] = true
    
    if v:IsA("BasePart") or v:IsA("MeshPart") then
        if not original[v] then
            original[v] = {Mat = v.Material, Shadow = v.CastShadow, Ref = v.Reflectance}
        end
        v.Material = Enum.Material.SmoothPlastic
        v.CastShadow = false
        v.Reflectance = 0
        
        if v:IsA("MeshPart") then
            if not original[v].MeshId then original[v].MeshId = v.MeshId end
            if not original[v].TextureId then original[v].TextureId = v.TextureId end
            v.TextureId = ""
            v.MeshId = ""
        end
    elseif v:IsA("SpecialMesh") then
        if not original[v] then original[v] = {TextureId = v.TextureId, MeshType = v.MeshType, MeshId = v.MeshId} end
        v.TextureId = ""
        v.MeshId = ""
        v.MeshType = Enum.MeshType.Box
    elseif v:IsA("Decal") or v:IsA("Texture") then
        if not original[v] then original[v] = {Texture = v.Texture, Trans = v.Transparency} end
        v.Texture = ""
        v.Transparency = 1
    elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") or v:IsA("Fire") or v:IsA("Smoke") or v:IsA("Sparkles") or v:IsA("Light") then
        if not original[v] then original[v] = {Enabled = v.Enabled} end
        v.Enabled = false
    elseif v:IsA("Sound") then
        if not original[v] then original[v] = {Vol = v.Volume} end
        v.Volume = 0
    end
end

local function toggleUIAnimations(state)
    local guis = LP.PlayerGui:GetChildren()
    for i = 1, #guis do
        local gui = guis[i]
        if gui ~= ScreenGui and gui:IsA("ScreenGui") then
            local children = gui:GetDescendants()
            for j = 1, #children do
                local child = children[j]
                if child:IsA("TweenScript") or child.Name:lower():find("anim") then
                    pcall(function() child.Disabled = not state end)
                end
            end
        end
    end
end

local function instantBoost()
    pcall(function()
        workspace.Terrain.WaterWaveSize = 0
        workspace.Terrain.WaterWaveSpeed = 0
        workspace.Terrain.WaterReflectance = 0
        workspace.Terrain.WaterTransparency = 0
        
        local settings = settings()
        settings.Rendering.QualityLevel = 1
        settings.Network.IncomingReplicationLag = 0
        
        sethiddenproperty(workspace.ClientAnimatorThrottling, "Enabled", true)
        sethiddenproperty(workspace, "InterpolationThrottling", "Default")
    end)

    local allObjects = workspace:GetDescendants()
    local batchSize = 700
    
    task.spawn(function()
        for i = 1, #allObjects do
            if not isEnabled then break end
            local obj = allObjects[i]
            if obj.Parent and not (obj.Parent:IsA("Model") and Players:GetPlayerFromCharacter(obj.Parent)) then
                optimize(obj)
            end
            if i % batchSize == 0 then
                task.wait()
            end
        end
    end)
    
    local allPlayers = Players:GetPlayers()
    for i = 1, #allPlayers do
        local player = allPlayers[i]
        if player.Character then
            optimizeCharacter(player.Character)
        end
    end
    
    if not original[Lighting] then
        original[Lighting] = {
            GlobalShadows = Lighting.GlobalShadows,
            OutdoorAmbient = Lighting.OutdoorAmbient,
            Ambient = Lighting.Ambient,
            Brightness = Lighting.Brightness,
            FogEnd = Lighting.FogEnd,
            FogStart = Lighting.FogStart
        }
    end
    
    Lighting.GlobalShadows = false
    Lighting.Brightness = 0
    Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
    Lighting.Ambient = Color3.fromRGB(255, 255, 255)
    Lighting.FogStart = 0
    Lighting.FogEnd = 999999
    
    local lightChildren = Lighting:GetChildren()
    for i = 1, #lightChildren do
        local v = lightChildren[i]
        if v:IsA("PostEffect") or v:IsA("Atmosphere") or v:IsA("Clouds") or v:IsA("Sky") then
            if not original[v] then original[v] = {Parent = v.Parent} end
            v.Parent = nil
        end
    end
    
    toggleUIAnimations(false)
end

UltraFastButton.MouseButton1Click:Connect(function()
    isEnabled = not isEnabled
    
    if isEnabled then
        UltraFastButton.Text = "Boost FPS: On"
