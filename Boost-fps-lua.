local function checkGameType()
    if workspace:FindFirstChild("Balls") or game:GetService("ReplicatedStorage"):FindFirstChild("Remotes") or workspace:FindFirstChild("Alive") then
        isBladeBall = true
    else
        isBladeBall = false
    end
end

local function checkIsBall(obj)
    if not obj then return false end
    local current = obj
    while current and current ~= workspace and current ~= game do
        local name = current.Name:lower()
        if name:find("ball") or name:find("volley") or name:find("sphere") or current:IsA("BallInning") then
            return true
        end
        current = current.Parent
    end
    return false
end

local function isEssentialObject(v)
    if checkIsBall(v) then return true end
    if v:IsDescendantOf(localPlayer.Character) then return true end
    
    local name = v.Name:lower()
    if name:find("court") or name:find("net") or name:find("floor") or name:find("line") or name:find("spawn") or name:find("arena") or name:find("plate") or name:find("base") or name:find("ground") or name:find("stadium") or name:find("platform") or name:find("zone") then
        return true
    end
    
    return false
end

local function optimizeOtherPlayers(hrpPosition)
    if not hrpPosition then return end
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= localPlayer and player.Character then
            local pRoot = player.Character:FindFirstChild("HumanoidRootPart")
            if pRoot then
                local dist = (pRoot.Position - hrpPosition).Magnitude
                if dist > 120 then
                    for _, part in pairs(player.Character:GetDescendants()) do
                        if part:IsA("BasePart") or part:IsA("MeshPart") then
                            if not originalStates[part] then originalStates[part] = { Transparency = part.Transparency } end
                            part.Transparency = 1
                        elseif part:IsA("Decal") or part:IsA("Texture") or part:IsA("ParticleEmitter") or part:IsA("Trail") or part:IsA("Beam") then
                            pcall(function() part:Destroy() end)
                        end
                    end
                end
            end
        end
    end
end

local function advancedPurgeAndOptimize(v)
    if not v then return end
    if isEssentialObject(v) then return end

    if v:IsA("ParticleEmitter") or v:IsA("Fire") or v:IsA("Smoke") or v:IsA("Sparkles") or v:IsA("Trail") or v:IsA("Beam") or v:IsA("Highlight") or v:IsA("SelectionBox") then
        pcall(function() v:Destroy() end)
        return
    end

    if v:IsA("Sound") then
        pcall(function()
            v.Playing = false
            v.Volume = 0
        end)
        return
    end

    if v:IsA("BasePart") or v:IsA("MeshPart") then
        local isPlayerPart = false
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character and v:IsDescendantOf(p.Character) then
                isPlayerPart = true
                break
            end
        end
        
        if not isPlayerPart then
            if not originalStates[v] then 
                originalStates[v] = { Material = v.Material, Color = v.Color, CastShadow = v.CastShadow, Reflectance = v.Reflectance, TextureId = v:IsA("MeshPart") and v.TextureId or nil } 
            end
            v.Material = Enum.Material.SmoothPlastic
            v.Color = Color3.fromRGB(30, 30, 33)
            v.CastShadow = false
            v.Reflectance = 0
            
            if not isBladeBall and v:IsA("MeshPart") and v.TextureId ~= "" then 
                v.TextureId = "" 
            end
        end
    end
    
    if not isBladeBall then
        if v:IsA("SpecialMesh") and v.TextureId ~= "" then
            if not originalStates[v] then originalStates[v] = { TextureId = v.TextureId } end
            v.TextureId = ""
        end
        if v:IsA("Decal") or v:IsA("Texture") then
            pcall(function() v:Destroy() end)
        end
    end
end

local function executeUltimateFusionBoost()
    checkGameType()
    
    pcall(function()
        settings().Rendering.QualityLevel = 1
        workspace.Terrain.WaterWaveSize = 0
        workspace.Terrain.WaterWaveSpeed = 0
        workspace.Terrain.WaterReflectance = 0
        workspace.Terrain.WaterTransparency = 0
    end)

    local character = localPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    local hrpPosition = hrp and hrp.Position or nil

    if hrpPosition then
        pcall(optimizeOtherPlayers, hrpPosition)
    end

    local allObjects = workspace:GetDescendants()
    for i = 1, #allObjects do
        advancedPurgeAndOptimize(allObjects[i])
    end
end

local function makeDraggable(frame)
    pcall(function()
        local dragging, dragInput, dragStart, startPos
        frame.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true; dragStart = input.Position; startPos = frame.Position
                input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
            end
        end)
        frame.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if input == dragInput and dragging then
                local delta = input.Position - dragStart
                frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end)
    end)
end
