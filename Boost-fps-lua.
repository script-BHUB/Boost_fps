local original = {}

local function optimizeCharacter(char)
    if not char or char == LP.Character then return end
    task.defer(function()
        task.wait(1)
        if not isEnabled or not char:IsDescendantOf(workspace) then return end
        for _, v in ipairs(char:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") or v:IsA("Highlight") or v:IsA("Sparkles") or v:IsA("Fire") or v:IsA("Smoke") then
                if not original[v] then original[v] = {Enabled = v.Enabled} end
                v.Enabled = false
            elseif v:IsA("BillboardGui") then
                if not original[v] then original[v] = {Enabled = v.Enabled} end
                v.Enabled = false
            elseif v:IsA("Decal") or v:IsA("Texture") then
                if not original[v] then original[v] = {Trans = v.Transparency} end
                v.Transparency = 1
            end
        end
    end)
end

local function optimize(v)
    if not v or not v:IsDescendantOf(workspace) then return end
    
    if v:IsA("Player") or (v.Parent and v.Parent:IsA("Model") and Players:GetPlayerFromCharacter(v.Parent)) then
        if v.Parent and v.Parent:IsA("Model") then
            optimizeCharacter(v.Parent)
        end
        return 
    end

    if v:IsA("BasePart") or v:IsA("MeshPart") then
        if not original[v] then
            original[v] = {Mat = v.Material, Col = v.Color, Shadow = v.CastShadow, Ref = v.Reflectance}
        end
        v.Material = Enum.Material.SmoothPlastic
        v.CastShadow = false
        v.Reflectance = 0
    elseif v:IsA("Sound") then
        if not original[v] then original[v] = {Vol = v.Volume} end
        v.Volume = 0
    elseif v:IsA("Decal") or v:IsA("Texture") then
        if not original[v] then original[v] = {Trans = v.Transparency} end
        v.Transparency = 1
    elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") or v:IsA("Fire") or v:IsA("Smoke") or v:IsA("Sparkles") then
        if not original[v] then original[v] = {Enabled = v.Enabled} end
        v.Enabled = false
    end
end

local function toggleUIAnimations(state)
    for _, gui in ipairs(LP.PlayerGui:GetChildren()) do
        if gui ~= ScreenGui and gui:IsA("ScreenGui") then
            for _, child in ipairs(gui:GetDescendants()) do
                if child:IsA("TweenScript") or child.Name:lower():find("anim") then
                    pcall(function() child.Disabled = not state end)
                end
            end
        end
    end
end

local function instantBoost()
    pcall(function()
        workspace.Terrain.WaterWaveSize = 0
        workspace.Terrain.WaterWaveSpeed = 0
        workspace.Terrain.WaterReflectance = 0
        workspace.Terrain.WaterTransparency = 0
    end)

    for _, v in ipairs(workspace:GetDescendants()) do
        optimize(v)
    end
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player.Character then
            optimizeCharacter(player.Character)
        end
    end
    
    if not original[Lighting] then
        original[Lighting] = {
            GlobalShadows = Lighting.GlobalShadows,
            OutdoorAmbient = Lighting.OutdoorAmbient,
            Ambient = Lighting.Ambient,
            Brightness = Lighting.Brightness
        }
    end
    
    Lighting.GlobalShadows = false
    Lighting.Brightness = 2.0
    Lighting.OutdoorAmbient = Color3.fromRGB(220, 220, 225)
    Lighting.Ambient = Color3.fromRGB(220, 220, 225)
    
    toggleUIAnimations(false)
end

UltraFastButton.MouseButton1Click:Connect(function()
    isEnabled = not isEnabled
    
    if isEnabled then
        UltraFastButton.Text = "Boost FPS: On"
        UltraFastButton.BackgroundColor3 = Color_On
        UltraFastButton.TextColor3 = TextColor_On
        UltraFastStroke.Color = Color3.fromRGB(0, 255, 180)
        StatLabel.Visible = true
        
        pcall(function()
            SG:SetCoreGuiEnabled(Enum.CoreGuiType.Chat, false)
            SG:SetCoreGuiEnabled(Enum.CoreGuiType.PlayerList, false)
        end)
        
        instantBoost()
        collectgarbage("collect")
    else
        UltraFastButton.Text = "Boost FPS: Off"
        UltraFastButton.BackgroundColor3 = Color_Off
        UltraFastButton.TextColor3 = TextColor_Off
        UltraFastStroke.Color = Color3.fromRGB(50, 50, 60)
        StatLabel.Visible = false
        
        pcall(function()
            SG:SetCoreGuiEnabled(Enum.CoreGuiType.Chat, true)
            SG:SetCoreGuiEnabled(Enum.CoreGuiType.PlayerList, true)
        end)
        
        if original[Lighting] then
            Lighting.GlobalShadows = original[Lighting].GlobalShadows
            Lighting.OutdoorAmbient = original[Lighting].OutdoorAmbient
            Lighting.Ambient = original[Lighting].Ambient
            Lighting.Brightness = original[Lighting].Brightness
        end
        
        toggleUIAnimations(true)
        
        for part, data in pairs(original) do
            pcall(function()
                if part and part.Parent then
                    if part:IsA("BillboardGui") or part:IsA("ParticleEmitter") or part:IsA("Trail") or part:IsA("Beam") or part:IsA("Fire") or part:IsA("Smoke") or part:IsA("Sparkles") then
                        part.Enabled = data.Enabled
                    elseif part:IsA("Decal") or part:IsA("Texture") then
                        part.Transparency = data.Trans
                    elseif part:IsA("Sound") then
                        part.Volume = data.Vol
                    elseif part ~= Lighting then
                        part.Material = data.Mat
                        part.CastShadow = data.Shadow
                        part.Reflectance = data.Ref
                    end
                end
            end)
        end
        original = {}
    end
end)

local function setupPlayerConnection(player)
    player.CharacterAdded:Connect(function(char)
        if isEnabled then
            optimizeCharacter(char)
        end
    end)
    if player.Character and isEnabled then
        optimizeCharacter(player.Character)
    end
end

for _, player in ipairs(Players:GetPlayers()) do
    setupPlayerConnection(player)
end
Players.PlayerAdded:Connect(setupPlayerConnection)

UIS.InputBegan:Connect(function(input, gpe)
    if not gpe and input.KeyCode == Enum.KeyCode.RightControl then
        MainFrame.Visible = not MainFrame.Visible
    end
end)

task.spawn(function()
    local lastTime = os.clock()
    local frameCount = 0
    RunService.Heartbeat:Connect(function()
        if StatLabel.Visible then
            frameCount = frameCount + 1
            local currentTime = os.clock()
            if currentTime - lastTime >= 0.5 then
                local fps = math.floor(frameCount / (currentTime - lastTime))
                frameCount = 0
                lastTime = currentTime
                local ping = 0
                pcall(function() ping = math.floor(LP:GetNetworkPing() * 1000) end)
                StatLabel.Text = "FPS: " .. fps .. " | PING: " .. ping .. "ms"
            end
        end
    end)
end)

task.spawn(function()
    while true do
        task.wait(30)
        if isEnabled then
            pcall(function()
                collectgarbage("collect")
                local chatScroller = LP.PlayerGui:FindFirstChild("Chat") and LP.PlayerGui.Chat:FindFirstChild("Frame") and LP.PlayerGui.Chat.Frame:FindFirstChild("ChatChannelParentFrame")
                if chatScroller then
                    local chatLabels = chatScroller:GetDescendants()
                    if #chatLabels > 50 then
                        for i = 1, #chatLabels - 50 do
                            if chatLabels[i]:IsA("TextLabel") then
                                chatLabels[i]:Destroy()
                            end
                        end
                    end
                end
            end)
        end
    end
end)

pcall(function()
    local dragStart, startPos
    MainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragStart = input.Position
            startPos = MainFrame.Position
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if dragStart and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragStart = nil
        end
    end)
end)
